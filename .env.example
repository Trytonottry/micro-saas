APP_NAME="LeadPing SaaS"
ENVIRONMENT="production"
DEBUG=false
SECRET_KEY="replace-with-long-random-string"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL="postgresql+psycopg2://postgres:postgres@db:5432/leadping"
REDIS_URL="redis://redis:6379/0"
DEFAULT_PLAN_NAME="starter"
STARTER_MONTHLY_LIMIT=200
GROWTH_MONTHLY_LIMIT=2000
PRO_MONTHLY_LIMIT=20000
RATE_LIMIT_PER_MINUTE=60
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-admin-password"
